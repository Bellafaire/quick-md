# Docker environment variables
# Copy this file to .env and customize as needed

# User and group IDs (automatically set to your user by default)
# USER_ID will be set automatically by: export USER_ID=$(id -u)
# GROUP_ID will be set automatically by: export GROUP_ID=$(id -g)

# Port for web server (default: 6580)
PORT=6580

# Optional: Password for web server (requires --password-protect flag)
# Uncomment and set to enable password protection
# QUICK_MD_PASSWORD=your_secure_password_here

# Optional: Custom paths for screenshots and videos
# Uncomment and set these if your media is outside the notebook directory
# SCREENSHOTS_PATH=/home/user/Pictures/Screenshots
# VIDEOS_PATH=/home/user/Videos
